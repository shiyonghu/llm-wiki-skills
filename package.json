{
  "name": "llm-wiki-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable skills for maintaining an Obsidian vault as an LLM wiki.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "skills:install-local": "bash scripts/install-local-wiki-skills.sh",
    "skills:list": "skills add . --list --full-depth",
    "skills:use:init": "skills use . --skill init-wiki --full-depth",
    "skills:use:ingest": "skills use . --skill ingest-wiki --full-depth",
    "skills:use:query": "skills use . --skill query-wiki --full-depth",
    "skills:use:lint": "skills use . --skill lint-wiki --full-depth",
    "test:archive-ingest-source": "bash scripts/test-archive-ingest-source.sh",
    "test:ingest-workflow-order": "bash scripts/test-ingest-workflow-order.sh",
    "test:install-local": "bash scripts/test-install-local-wiki-skills.sh"
  },
  "devDependencies": {
    "skills": "1.5.13"
  },
  "engines": {
    "node": ">=18"
  }
}
